# --- Database (Vercel Postgres injects POSTGRES_URL automatically when linked) ---
POSTGRES_URL="postgres://user:password@host/dbname?sslmode=require"

# --- Auth.js: generate with `openssl rand -base64 32` ---
AUTH_SECRET="replace-with-a-long-random-string"

# --- Protects the daily cron endpoint (any random string) ---
CRON_SECRET="replace-with-a-random-string"

# --- Seed admin account (used by `npm run db:seed`) ---
SEED_ADMIN_EMAIL="admin@tindie.test"
SEED_ADMIN_PASSWORD="changeme123"

# --- OPTIONAL: only needed once you wire the real AI summarizer in src/lib/pipeline.ts ---
# ANTHROPIC_API_KEY="sk-ant-..."
